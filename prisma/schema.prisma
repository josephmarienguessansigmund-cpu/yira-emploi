generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Jeune {
  id                  String   @id @default(cuid())
  nom                 String
  prenom              String
  telephone           String   @unique
  email               String?
  dateNaissance       DateTime?
  genre               String?    // "M", "F"
  niveau              String?
  specialite          String?
  situationActuelle   String?    // "NEET", "EMPLOYE", "ETUDIANT", "AUTRE"
  district            String?
  commune             String?
  quartier            String?
  zoneGeo             String?    // "urbain", "periurbain", "rural"
  canalPrefere        String?    // "sms", "whatsapp", "appel"
  consentementRGPD    Boolean    @default(false)
  codeYira            String?    @unique
  statutParcours      String     @default("INSCRIT") // INSCRIT, EN_EVALUATION, EVALUE, EN_FORMATION, CERTIFIE, INSERE
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  testsSigmund        TestSigmund[]
  paiements           Paiement[]
}

model TestSigmund {
  id                  String    @id @default(cuid())
  jeuneId             String
  jeune               Jeune     @relation(fields: [jeuneId], references: [id])
  sigmundTestId       String?
  completedAt         DateTime?
  estValideParExpert  Boolean   @default(false)
  rapport             String?
  createdAt           DateTime  @default(now())
}

model Paiement {
  id          String   @id @default(cuid())
  jeuneId     String
  jeune       Jeune    @relation(fields: [jeuneId], references: [id])
  montant     Float
  statut      String   @default("pending")
  operateur   String?
  reference   String?
  createdAt   DateTime @default(now())
}